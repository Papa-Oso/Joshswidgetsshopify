{% liquid
  assign headline = collection.title
  assign description = collection.description
  assign is_helmet = false
  assign is_bmw = false
  assign is_other = false

  if collection.handle contains 'helmet' or collection.handle contains 'cardo' or collection.title contains 'Helmet' or collection.title contains 'Cardo'
    assign is_helmet = true
    assign headline = 'Cardo Helmet Adapters'
    if description == blank
      assign description = 'Shop helmet-specific adapter mounts designed to help compatible Cardo communicators mount cleanly to select factory helmet communication locations. Confirm your exact helmet model and Cardo device before ordering.'
    endif
  elsif collection.handle contains 'bmw' or collection.title contains 'BMW'
    assign is_bmw = true
    assign headline = 'BMW Z3 & M Roadster Parts'
    if description == blank
      assign description = 'Practical replacement and upgrade parts for BMW Z3 and M Roadster owners, including seat belt guide repair clips, visor delete plates, and gauge pod accessories.'
    endif
  elsif collection.handle contains 'other' or collection.title contains 'Other'
    assign is_other = true
    assign headline = 'Other Practical Parts'
    if description == blank
      assign description = 'Small, purpose-built accessories designed to solve real-world problems for vehicles, gear, and everyday equipment.'
    endif
  endif
%}

<section class="jws-page-hero">
  <div class="jws-page-hero__inner">
    <p class="jws-eyebrow">{% if is_helmet %}Helmet-specific fitment{% elsif is_bmw %}Owner-focused parts{% elsif is_other %}Useful small parts{% else %}Shop{% endif %}</p>
    <h1>{{ headline }}</h1>
    <p>{{ description }}</p>
    {% if is_helmet %}
      <div class="jws-alert">
        <p><strong>Fitment matters:</strong> These adapters are not universal. Confirm your exact helmet model and Cardo communicator before ordering.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Josh's Widgets collection banner",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Josh's Widgets collection banner"
    }
  ]
}
{% endschema %}
