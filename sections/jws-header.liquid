<header class="jws-header" role="banner">
  <div class="jws-header__inner">
    <a class="jws-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      <span class="jws-logo__mark">JW</span>
      <span class="jws-logo__text">
        <span class="jws-logo__name">{{ section.settings.logo_text }}</span>
        <span class="jws-logo__tagline">{{ section.settings.logo_tagline }}</span>
      </span>
    </a>

    <nav class="jws-nav" aria-label="Primary navigation">
      <a href="/collections/helmet-adapters">Shop Helmet Adapters</a>
      <a href="/collections/bmw-z3-m-roadster-parts">Shop BMW Parts</a>
      <a href="/collections/other-practical-parts">Other Parts</a>
      <a href="/pages/find-your-fit">Find Your Fit</a>
      <a href="/pages/installation-guides">Installation Guides</a>
      <a href="/pages/about">About</a>
      <a href="/pages/support">Support</a>
    </nav>

    <div class="jws-header__actions">
      <a class="jws-header__icon" href="{{ routes.search_url }}" aria-label="Search">
        {{ 'icon-search.svg' | inline_asset_content }}
      </a>
      {% if shop.customer_accounts_enabled %}
        <a class="jws-header__icon" href="{{ routes.account_url }}" aria-label="Account">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}
      <a class="jws-header__icon" href="{{ routes.cart_url }}" aria-label="Cart">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="jws-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <details class="jws-mobile-menu">
        <summary class="jws-menu-toggle" aria-label="Open menu">
          {{ 'icon-menu.svg' | inline_asset_content }}
        </summary>
        <nav class="jws-mobile-nav" aria-label="Mobile navigation">
          <a href="/collections/helmet-adapters">Shop Helmet Adapters</a>
          <a href="/collections/bmw-z3-m-roadster-parts">Shop BMW Parts</a>
          <a href="/collections/other-practical-parts">Other Parts</a>
          <a href="/pages/find-your-fit">Find Your Fit</a>
          <a href="/pages/installation-guides">Installation Guides</a>
          <a href="/pages/about">About</a>
          <a href="/pages/support">Support</a>
        </nav>
      </details>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Josh's Widgets header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Josh's Widgets"
    },
    {
      "type": "text",
      "id": "logo_tagline",
      "label": "Logo tagline",
      "default": "Purpose-built parts"
    }
  ],
  "presets": [
    {
      "name": "Josh's Widgets header"
    }
  ]
}
{% endschema %}
