{% liquid
  assign helmet_collection = section.settings.helmet_collection
  if helmet_collection == blank
    assign helmet_collection = collections['helmet-adapters']
  endif
%}

<div class="jws-page" data-jws-fit-finder>
  <section class="jws-page-hero">
    <div class="jws-page-hero__inner">
      <p class="jws-eyebrow">Compatibility guide</p>
      <h1>Find Your Fit</h1>
      <p>The right adapter depends on two things: your exact helmet model and your exact Cardo communicator. Start with your helmet, then confirm your communicator before ordering.</p>
    </div>
  </section>

  <section class="jws-page-body">
    <div class="jws-page-body__inner">
      <div class="jws-section__header">
        <h2>Choose Your Setup</h2>
        <p>Use the filters below to narrow live products from the helmet adapter collection. Product pages contain the final compatibility details.</p>
      </div>

      <div class="jws-finder">
        <div class="jws-finder__grid">
          <div class="jws-field">
            <label for="FitHelmetBrand">Helmet brand</label>
            <select id="FitHelmetBrand" data-jws-filter="helmetBrand">
              <option value="">Any brand</option>
              <option value="HJC">HJC</option>
              <option value="Shoei">Shoei</option>
              <option value="NEXX">NEXX</option>
              <option value="Scorpion">Scorpion</option>
            </select>
          </div>
          <div class="jws-field">
            <label for="FitHelmetModel">Helmet model</label>
            <select id="FitHelmetModel" data-jws-filter="helmetModel">
              <option value="">Any model</option>
              <option value="HJC">HJC factory communication mount</option>
              <option value="Neotec II">Shoei Neotec II</option>
              <option value="GT-Air II">Shoei GT-Air II</option>
              <option value="X-COM3">NEXX X-COM3</option>
              <option value="EXO-COM">Scorpion EXO-COM</option>
            </select>
          </div>
          <div class="jws-field">
            <label for="FitCardo">Cardo communicator</label>
            <select id="FitCardo" data-jws-filter="cardo">
              <option value="">Any Cardo unit</option>
              <option value="Packtalk Edge">Packtalk Edge</option>
              <option value="Packtalk Neo">Packtalk Neo</option>
              <option value="Packtalk Pro">Packtalk Pro</option>
              <option value="Packtalk Custom">Packtalk Custom</option>
              <option value="Packtalk Bold">Packtalk Bold</option>
              <option value="Freecom">Freecom</option>
              <option value="Spirit">Spirit</option>
              <option value="Spirit HD">Spirit HD</option>
            </select>
          </div>
          <div class="jws-field">
            <label for="FitAdapterType">Adapter type</label>
            <select id="FitAdapterType" data-jws-filter="adapterType">
              <option value="">Any adapter</option>
              <option value="Helmet adapter">Helmet adapter</option>
              <option value="Edge">Packtalk Edge-style</option>
              <option value="Bold">Packtalk Bold</option>
              <option value="Freecom">Freecom / Spirit</option>
            </select>
          </div>
        </div>
        <div class="jws-help-links">
          <span data-jws-count></span>
          <button type="button" class="button-secondary" data-jws-clear>Clear filters</button>
          <a class="jws-link" href="#fitment-help">Still unsure? Send your helmet model and Cardo device before ordering.</a>
        </div>
      </div>

      {% if helmet_collection != blank and helmet_collection.products_count > 0 %}
        <div class="jws-grid jws-grid--cards" style="margin-top: 1.25rem;">
          {% for product in helmet_collection.products limit: 24 %}
            {% render 'jws-product-card', product: product %}
          {% endfor %}
        </div>
        <div class="jws-empty-state" data-jws-empty hidden>
          <p>No matching products are visible for that exact combination. Contact Josh before ordering if you are unsure.</p>
        </div>
      {% else %}
        <div class="jws-alert" style="margin-top: 1.25rem;">
          <p>No helmet adapter products are visible right now. Contact Josh's Widgets before ordering if you need help confirming a specific setup.</p>
        </div>
      {% endif %}
    </div>
  </section>

  <section class="jws-section jws-section--white">
    <div class="jws-section__inner">
      <div class="jws-section__header">
        <h2>Manual Compatibility Table</h2>
        <p>This table is generated from live product metafields when available. Always use the product page as the final source before ordering.</p>
      </div>
      <div class="jws-table-wrap">
        <table class="jws-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Helmet</th>
              <th>Compatible Cardo units</th>
              <th>Not compatible with</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {% if helmet_collection != blank and helmet_collection.products_count > 0 %}
              {% for product in helmet_collection.products limit: 50 %}
                <tr>
                  <td><a class="jws-link" href="{{ product.url }}">{{ product.title }}</a></td>
                  <td>{{ product.metafields.custom.helmet_brand | metafield_text }} {{ product.metafields.custom.helmet_model | metafield_text }}</td>
                  <td>{{ product.metafields.custom.cardo_compatible_devices | metafield_text | default: 'See product page' }}</td>
                  <td>{{ product.metafields.custom.cardo_incompatible_devices | metafield_text | default: 'See product page' }}</td>
                  <td>{{ product.metafields.custom.compatibility_warning | metafield_text | default: 'Confirm exact helmet and Cardo setup before ordering.' }}</td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="5">No live helmet adapter products are visible right now.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="jws-section" id="fitment-help">
    <div class="jws-section__inner jws-split">
      <div>
        <p class="jws-eyebrow">Fitment help</p>
        <h2>Still Not Sure?</h2>
        <p>Send your helmet brand, exact helmet model, and Cardo device before ordering. Do not guess between Cardo product families or helmet communication systems.</p>
      </div>
      {% form 'contact', class: 'jws-form' %}
        <input type="hidden" name="contact[Reason]" value="Fitment help">
        <div class="jws-form__grid">
          <div class="jws-field">
            <label for="FitName">Name</label>
            <input id="FitName" type="text" name="contact[name]" autocomplete="name" required>
          </div>
          <div class="jws-field">
            <label for="FitEmail">Email</label>
            <input id="FitEmail" type="email" name="contact[email]" autocomplete="email" required>
          </div>
          <div class="jws-field">
            <label for="FitBrand">Helmet Brand</label>
            <input id="FitBrand" type="text" name="contact[Helmet Brand]">
          </div>
          <div class="jws-field">
            <label for="FitModel">Helmet Model</label>
            <input id="FitModel" type="text" name="contact[Helmet Model]">
          </div>
          <div class="jws-field jws-field--full">
            <label for="FitCardoDevice">Cardo Device</label>
            <input id="FitCardoDevice" type="text" name="contact[Cardo Device]">
          </div>
          <div class="jws-field jws-field--full">
            <label for="FitMessage">Message</label>
            <textarea id="FitMessage" name="contact[body]"></textarea>
          </div>
        </div>
        <button class="button" type="submit">Send fitment question</button>
        {% if form.posted_successfully? %}
          <p>Thanks. Your fitment question was sent.</p>
        {% elsif form.errors %}
          <p>{{ form.errors | default_errors }}</p>
        {% endif %}
      {% endform %}
    </div>
  </section>
</div>

<script src="{{ 'jws-fit-finder.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Find Your Fit page",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "helmet_collection",
      "label": "Helmet adapter collection"
    }
  ],
  "presets": [
    {
      "name": "Find Your Fit page"
    }
  ]
}
{% endschema %}
