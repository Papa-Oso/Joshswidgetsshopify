<div class="jws-page">
  <section class="jws-page-hero">
    <div class="jws-page-hero__inner">
      <p class="jws-eyebrow">Store policy</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.intro }}</p>
    </div>
  </section>

  <section class="jws-page-body">
    <div class="jws-page-body__inner">
      {% if page.content != blank %}
        <div class="rte">{{ page.content }}</div>
      {% else %}
        {% case section.settings.policy_type %}
          {% when 'shipping' %}
            <div class="jws-grid">
              <article class="jws-guide-card"><h3>Free U.S. Shipping</h3><p>Free U.S. shipping is available on all products.</p></article>
              <article class="jws-guide-card"><h3>International Orders</h3><p>International shipping may be calculated at checkout if enabled. International customers may be responsible for duties, taxes, and import fees.</p></article>
              <article class="jws-guide-card"><h3>Delivery Estimates</h3><p>Delivery timing depends on carrier services and checkout options. Do not rely on delivery promises unless they are carrier-backed at checkout.</p></article>
            </div>
          {% when 'returns' %}
            <div class="jws-grid">
              <article class="jws-guide-card"><h3>Before Ordering</h3><p>Confirm fitment before checkout. These adapters are not universal.</p></article>
              <article class="jws-guide-card"><h3>Returns and Exchanges</h3><p>Use the merchant-configured return policy for the current return window, condition requirements, and process.</p></article>
              <article class="jws-guide-card"><h3>Wrong Adapter</h3><p>If you think you ordered the wrong adapter, contact support with your order number, helmet model, and Cardo device.</p></article>
            </div>
          {% else %}
            <div class="jws-alert">
              <p>The current policy text is being finalized. Contact Josh's Widgets with questions before ordering.</p>
            </div>
        {% endcase %}
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Policy page",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Store Policy"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Review the current store policy before ordering."
    },
    {
      "type": "select",
      "id": "policy_type",
      "label": "Policy type",
      "options": [
        {"value": "shipping", "label": "Shipping"},
        {"value": "returns", "label": "Returns"},
        {"value": "general", "label": "General"}
      ],
      "default": "general"
    }
  ],
  "presets": [
    {
      "name": "Policy page"
    }
  ]
}
{% endschema %}
