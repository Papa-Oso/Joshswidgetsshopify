{% liquid
  assign card_product = product
  assign helmet_brand = card_product.metafields.custom.helmet_brand | metafield_text
  assign helmet_model = card_product.metafields.custom.helmet_model | metafield_text
  assign cardo_devices = card_product.metafields.custom.cardo_compatible_devices | metafield_text
  assign product_category = card_product.metafields.custom.product_category | metafield_text
  assign compatibility_warning = card_product.metafields.custom.compatibility_warning | metafield_text

  assign compatibility_tag = cardo_devices
  if compatibility_tag == blank
    assign compatibility_tag = helmet_model
  endif
  if compatibility_tag == blank
    assign compatibility_tag = product_category
  endif
  if compatibility_tag == blank
    assign compatibility_tag = 'Confirm exact fitment'
  endif

  assign adapter_data = product_category | append: ' ' | append: card_product.title | append: ' ' | append: card_product.tags
  assign image_alt = card_product.featured_image.alt | default: card_product.title | escape
%}

<article
  class="jws-product-card"
  data-jws-product-card
  data-helmet-brand="{{ helmet_brand | default: card_product.vendor | escape }}"
  data-helmet-model="{{ helmet_model | escape }}"
  data-cardo="{{ cardo_devices | escape }}"
  data-adapter-type="{{ adapter_data | escape }}"
>
  <a class="jws-product-card__media" href="{{ card_product.url }}" aria-label="{{ card_product.title | escape }}">
    {% if card_product.featured_image %}
      {{
        card_product.featured_image
        | image_url: width: 760
        | image_tag:
          loading: 'lazy',
          alt: image_alt,
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw'
      }}
    {% else %}
      <span class="jws-product-card__empty" aria-hidden="true"></span>
      <span class="visually-hidden">No product image available</span>
    {% endif %}
  </a>

  <div class="jws-product-card__body">
    <span class="jws-product-card__tag">{{ compatibility_tag }}</span>
    <h3>
      <a href="{{ card_product.url }}">{{ card_product.title }}</a>
    </h3>
    <div class="jws-product-card__price">
      {% render 'price', product_resource: card_product, show_sale_price_first: true %}
    </div>
    <span class="jws-product-card__shipping">Free U.S. Shipping</span>
    {% if compatibility_warning != blank %}
      <p>{{ compatibility_warning }}</p>
    {% endif %}
    <a class="jws-link" href="{{ card_product.url }}">View detailed compatibility</a>
  </div>
</article>
